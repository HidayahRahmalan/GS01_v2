<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 1. Pastikan GS01 menggunakan HURUF BESAR sepadan dengan nama folder di server
    RewriteBase /2026/all/GroupMDB/GS01/

    # 2. Elakkan looping: Jika request sudah ke public/, skip rule ini
    RewriteCond %{REQUEST_URI} !^/2026/all/GroupMDB/GS01/public/

    # 3. Hala semuanya ke folder public Laravel
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>