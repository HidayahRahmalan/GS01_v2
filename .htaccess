<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 📌 1. Halakan base path tepat ke folder projek Laravel bertingkat awak
    RewriteBase /2026/all/GroupMDB/GS01/GS01/

    # 📌 2. Elakkan looping: Semak jika URL belum ada perkataan /public/
    RewriteCond %{REQUEST_URI} !/public/

    # 📌 3. Tolak trafik masuk ke dalam folder public Laravel secara senyap
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>